{
  "name": "pipedrive-mcp",
  "version": "0.1.0",
  "description": "MCP server for Pipedrive CRM",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:sse": "node dist/index.js --transport sse",
    "dev": "tsx src/index.ts",
    "dev:sse": "tsx src/index.ts --transport sse",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "setup": "tsx src/bin/setup.ts",
    "revoke": "tsx src/bin/revoke.ts",
    "audit-verify": "tsx src/bin/audit-verify.ts",
    "kill-switch": "tsx src/bin/kill-switch.ts",
    "prebuild": "node scripts/embed-version.mjs",
    "security:check": "bash scripts/check-forbidden-patterns.sh && node scripts/check-lifecycle-scripts.mjs && npm audit --audit-level=high --production"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "dependencies": {
    "@modelcontextprotocol/sdk": "~1.29.0",
    "better-sqlite3": "~11.10.0",
    "fastest-levenshtein": "1.0.16",
    "keytar": "~7.9.0",
    "pino": "~10.3.1",
    "striptags": "~3.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
